KIS_APP_KEY=your_kis_app_key
KIS_APP_SECRET=your_kis_app_secret
KIS_BASE_URL=https://openapi.koreainvestment.com:9443

GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/your_deployment_id/exec
SNAPSHOT_TOKEN=make_a_long_random_token
TICKERS_CSV_URL=https://docs.google.com/spreadsheets/d/e/your_published_tickers_csv_url/pub?gid=0&single=true&output=csv

# Optional
SNAPSHOT_CSV_PATH=latest_snapshot.csv
GENERATE_REPORT=true
REPORT_PATH=latest_report.md
REPORT_TYPE=intraday
FORCE_RUN=false
REQUIRE_GOOGLE_SYNC=false
